Cell[BoxData[{
 RowBox[{
  RowBox[{"V", " ", "=", " ", 
   RowBox[{"8", "^", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalLambda]", " ", "=", " ", "0.07509097762269842"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"QN2", " ", "=", " ", 
  RowBox[{
   FractionBox[
    SuperscriptBox["V", "2"], 
    RowBox[{"2", "*", 
     SuperscriptBox["\[CapitalLambda]", "6"]}]], " ", "+", " ", 
