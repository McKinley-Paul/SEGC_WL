Cell["E_12_frac_LJ:", "Text",
 CellChangeTimes->{{3.973272976451145*^9, 
  3.973272979302641*^9}},ExpressionUUID->"4729a503-6133-4760-af7d-\
dba293e30f8a"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Phi]", "[", 
     RowBox[{"r_", ",", "\[Lambda]_", ",", "M_"}], "]"}], ":=", 
    RowBox[{"4", "*", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["\[Lambda]", "M"], ")"}], 
      FractionBox["1", "3"]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["\[Lambda]", "M"], ")"}], 
           RowBox[{"1", "/", "4"}]], "r"], " ", ")"}], "12"], "-", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["\[Lambda]", "M"], ")"}], 
           RowBox[{"1", "/", "4"}]], "r"], ")"}], "6"]}], "  ", ")"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rList", "=", 
     RowBox[{"{", 
      RowBox[{
      "0.0001", ",", "1.0", ",", "2.0", ",", "10.0", ",", "30.0", ",", "5.6", 
       ",", "100000000000.0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"rListSqrt", "=", 
    RowBox[{"Sqrt", "[", "rList", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9732733954572487`*^9, 3.973273586704084*^9}, {
  3.9732737112508097`*^9, 3.973273763925448*^9}},
