Cell[CellGroupData[{

Cell["Physics test: Q(N=1|V,T) test", "Section",
 CellChangeTimes->{{3.9743933881483173`*^9, 3.974393395722169*^9}, {
  3.974396269980378*^9, 
  3.9743962715677023`*^9}},ExpressionUUID->"9baf848a-f160-4ad6-bc8d-\
2e9d41cad9fb"],

Cell[TextData[{
 "We have the partition function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["Q", "TI"], 
          RowBox[{"(", 
            RowBox[{
              StyleBox["N", "TI"], ",", 
              StyleBox["V", "TI"], ",", 
              StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
          FractionBox["1", 
           RowBox[{
             StyleBox["N", "TI"], "!", 
             SuperscriptBox[
              StyleBox["h", "TI"], 
              RowBox[{"3", 
                StyleBox["N", "TI"]}]]}]], "\[Integral]", "\[Integral]", 
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"-", "\[Beta]", 
             StyleBox["H", "TI"]}]], 
          SuperscriptBox[
           StyleBox["d", "TI"], 
           RowBox[{"3", 
             StyleBox["N", "TI"]}]], 
          StyleBox["r", "TI"], 
          SuperscriptBox[
           StyleBox["d", "TI"], 
           RowBox[{"3", 
             StyleBox["N", "TI"]}]], 
          StyleBox["p", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "$Q(N,V,T) = \\frac{1}{N! h^{3N}} \\int \\int e^{-\\beta H} \
d^{3N}rd^{3N}p$", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "d1f82423-cc9c-42e7-b70e-c7fbf617b378"],
 "which after solving the momenta integral becomes:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            StyleBox["N", "TI"], "!", 
            SuperscriptBox["\[CapitalLambda]", 
             RowBox[{"3", 
               StyleBox["N", "TI"]}]]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["H", "TI"]}]], 
         SuperscriptBox[
          StyleBox["d", "TI"], 
          RowBox[{"3", 
            StyleBox["N", "TI"]}]], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$Q(N,V,T) = \\frac{1}{N! \\Lambda^{3N}}  \\int e^{-\\beta H} d^{3N}r $",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "118b0362-2888-421b-80a4-db38b069bfc8"],
 "  . naturally the position coordinates are in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["i", "TI"]], "\[Element]", 
         RowBox[{"[", 
           RowBox[{"-", 
             FractionBox[
              StyleBox["L", "TI"], "2"], ",", 
             FractionBox[
              StyleBox["L", "TI"], "2"]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "$r_i \\in [-\\frac{L}{2},\\frac{L}{2}]$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e62e5a91-736d-4943-9f35-598bab117d12"],
 " but following Desgranges and Allen and Tildesly, we want to rescale them \
to a unit box for ease of simulation thuse make the change of coordinates ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalGamma]", 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         FractionBox["1", 
          StyleBox["L", "TI"]], 
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["i", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Gamma_i = \\frac{1}{L}r_i$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7af60db6-c902-4a65-a9e4-44dff4307fdb"],
 " so that now ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox["\[CapitalGamma]", "\[RightVector]"], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\vec{\\Gamma}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee1dfad2-ed9c-4be8-b8ee-97ea34633c29"],
 " lives in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalGamma]", 
          StyleBox["i", "TI"]], "\[Element]", 
         RowBox[{"[", 
           RowBox[{"-0.5", ",", "+0.5"}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\Gamma_i \\in [-0.5,+0.5]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f6a5a722-0b53-4400-8e74-bc78b0c44af4"],
 ". From this transformation we get a factor of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["V", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$V$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b65e3a46-373f-428a-a6ec-84514b22b069"],
 " for each particle. And thus we get the Desgranges expression of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], ",", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["V", "TI"], 
           StyleBox["N", "TI"]], 
          RowBox[{
            StyleBox["N", "TI"], "!", 
            SuperscriptBox["\[CapitalLambda]", 
             RowBox[{"3", 
               StyleBox["N", "TI"]}]]}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            StyleBox["U", "TI"], 
            RowBox[{"(", "\[CapitalGamma]", ")"}]}]], 
         StyleBox["d", "TI"], "\[CapitalGamma]"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$Q(N,V,T) = \\frac{V^N}{N! \\Lambda^{3N}}  \\int e^{-\\beta U(\\Gamma)} \
d\\Gamma $", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a5fce1ce-1649-43a7-a3d3-26116242a2cd"],
 " for N=1, there are no interactions with other particles (and in our \
present situation no interactions with an external field) so ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["U", "TI"], 
         RowBox[{"(", "\[CapitalGamma]", ")"}], "\[LongEqual]", "0", 
         "\[ForAll]\[CapitalGamma]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$U(\\Gamma) = 0 \\forall \\Gamma$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a2cca665-b241-449d-9459-67648c664091"],
 " thus \n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Q", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["N", "TI"], "\[LongEqual]", "1", ",", "\[Lambda]", 
             "\[LongEqual]", "0|", 
             StyleBox["V", "TI"], ",", 
             StyleBox["T", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["V", "TI"], 
          SuperscriptBox["\[CapitalLambda]", "3"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "Q(N=1,\\lambda=0|V,T) = \\frac{V}{\\Lambda^3}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"70134c79-764c-4c8d-a568-0c07e01ce5d2"],
 StyleBox[" which gives us our first test of the system wide physics.",
  FontWeight->"Bold"],
 " For L=8 ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Sigma]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\sigma", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8471e48c-ab51-462f-bd7c-523ae1b085a5"],
 " , V = 512 ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Sigma]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\sigma", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13e49146-7580-46be-b1a5-376c4c232020"],
 " "
}], "Text",
 CellChangeTimes->{{3.974393414565881*^9, 3.97439367118149*^9}, {
  3.974393714721774*^9, 3.97439388649279*^9}, {3.974393928601233*^9, 
  3.974393969393299*^9}},ExpressionUUID->"636f6304-73d8-4889-aed7-\
c7766e042b4b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"V", " ", "=", " ", 
  RowBox[{"8", "^", "3"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalLambda]", " ", "=", " ", "0.07509097762269842"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"for", " ", "argon_deBroglie", " ", "at", " ", "T"}], "*=", "1"}],
    " ", "*)"}]}], "\[IndentingNewLine]", 
 FractionBox["V", 
  SuperscriptBox["\[CapitalLambda]", "3"]], "\[IndentingNewLine]", 
 RowBox[{"Log", "[", 
  FractionBox["V", 
   SuperscriptBox["\[CapitalLambda]", "3"]], "]"}]}], "Input",
 CellChangeTimes->{{3.974393953277602*^9, 3.974393955018016*^9}, {
  3.97439403776982*^9, 3.9743940999764643`*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"52f4fe66-a502-499c-8eb2-59950dd12c7f"],

Cell[BoxData["512"], "Output",
 CellChangeTimes->{
  3.9743939553125668`*^9, {3.9743940796124077`*^9, 3.974394100687742*^9}},
 CellLabel->"Out[93]=",ExpressionUUID->"0cd50831-0740-4905-8d40-f91c381e827d"],

Cell[BoxData["0.07509097762269842`"], "Output",
 CellChangeTimes->{
  3.9743939553125668`*^9, {3.9743940796124077`*^9, 3.97439410068876*^9}},
 CellLabel->"Out[94]=",ExpressionUUID->"41528595-3c77-4a0c-b926-60755cd4c538"],

Cell[BoxData["1.2092237972648472`*^6"], "Output",
 CellChangeTimes->{
  3.9743939553125668`*^9, {3.9743940796124077`*^9, 3.974394100689762*^9}},
 CellLabel->"Out[95]=",ExpressionUUID->"976f186c-db33-4246-a9ba-caa839ba0e69"],

Cell[BoxData["14.005489221866503`"], "Output",
 CellChangeTimes->{
  3.9743939553125668`*^9, {3.9743940796124077`*^9, 3.9743941006906967`*^9}},
