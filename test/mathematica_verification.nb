Cell[BoxData[
 FormBox["", TraditionalForm]], "Input",
 CellChangeTimes->{
  3.974477994476598*^9},ExpressionUUID->"595bcd90-ca39-48ec-8b3d-\
860f3743b37c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Q", "[", 
   RowBox[{"N_", ",", "V_", ",", "\[CapitalLambda]_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"N", "!"}]], 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["V", 
      SuperscriptBox["\[CapitalLambda]", "3"]], ")"}], 
    "N"]}]}], "\[IndentingNewLine]", 
 RowBox[{"Log", "[", 
  RowBox[{"Q", "[", 
   RowBox[{"2", ",", 
